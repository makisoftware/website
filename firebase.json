{
  "hosting": {
    "public": "build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "redirects": [
      {
        "source": "/capture/oauth-callback",
        "destination": "capture://oauth-callback",
        "type": 302
      }
    ]
  }
}